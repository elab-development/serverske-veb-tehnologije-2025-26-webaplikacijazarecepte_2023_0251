    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "POST /api/auth/login (6 times - should hit limit)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const count = pm.environment.get('loginAttempts') || 0;",
                  "pm.environment.set('loginAttempts', count + 1);",
                  "if (count >= 5) {",
                  "    pm.test('Rate limited (429 or 200)', () => {",
                  "        pm.expect(pm.response.code).to.be.oneOf([429, 200]);",
                  "    });",
                  "} else {",
                  "    pm.test('Allowed through', () => pm.response.to.have.status(401));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test\",\n  \"password\": \"test\"\n}"
            },
